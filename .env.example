# Database (PostgreSQL)
# Local: postgresql://user:password@localhost:5432/fittrack
# Supabase: found in Settings > Database > Connection string
# Railway: found in your Railway project variables
DATABASE_URL="postgresql://user:password@localhost:5432/fittrack"

# NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# App URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
